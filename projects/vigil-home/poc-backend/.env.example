# Vigil Home — Environment Variables Example
# Copy this file to .env and fill in your values.
# Or set these as environment variables in your deployment environment.

# ── Authentication ─────────────────────────────────────────────────

# Admin credentials (set on first start)
VIGIL_ADMIN_USERNAME=admin
VIGIL_ADMIN_PASSWORD=changeme

# Alternative: read password from file (more secure for systemd/docker)
# VIGIL_ADMIN_PASSWORD_FILE=/run/secrets/admin_password

# JWT signing secret (auto-generated if not provided)
# For production: generate with `openssl rand -hex 32`
# VIGIL_JWT_SECRET=your-secret-key-here

# Alternative: read JWT secret from file
# VIGIL_JWT_SECRET_FILE=/run/secrets/jwt_secret

# Auth bypass for development ONLY (never use in production!)
# VIGIL_AUTH_DISABLED=false

# Token expiry (optional, defaults shown)
# VIGIL_ACCESS_TOKEN_EXPIRE_MINUTES=60
# VIGIL_REFRESH_TOKEN_EXPIRE_DAYS=30

# ── Database ──────────────────────────────────────────────────────

# SQLite database path (ensure directory exists and is writable)
VIGIL_DB_PATH=/data/vigil.db

# ── Suricata Integration ──────────────────────────────────────────

# Path to Suricata eve.json log file
VIGIL_EVE_JSON=/var/log/suricata/eve.json

# Poll interval for eve.json (seconds)
VIGIL_POLL_INTERVAL=2.0

# ── Email Notifications ───────────────────────────────────────────

# SMTP provider: gmail, icloud, m365, custom
VIGIL_SMTP_PROVIDER=gmail

# Gmail SMTP (if using Gmail)
GMAIL_USER=your-email@gmail.com
GMAIL_APP_PASSWORD=your-app-password

# iCloud SMTP (if using iCloud)
# ICLOUD_USER=your-email@icloud.com
# ICLOUD_APP_PASSWORD=your-app-password

# Microsoft 365 (if using M365 with SMTP)
# M365_CLIENT_ID=your-client-id
# M365_TENANT_ID=your-tenant-id
# M365_CLIENT_SECRET=your-client-secret

# Custom SMTP
# VIGIL_SMTP_HOST=smtp.example.com
# VIGIL_SMTP_PORT=587
# VIGIL_SMTP_USER=your-email@example.com
# VIGIL_SMTP_PASSWORD=your-password
# VIGIL_SMTP_TLS=true

# Email sender and recipient
VIGIL_ALERT_FROM=vigil@yourdomain.com
VIGIL_ALERT_TO=admin@yourdomain.com

# Email rate limiting (optional)
# VIGIL_EMAIL_WINDOW=3600
# VIGIL_EMAIL_MAX=10

# ── Dashboard ─────────────────────────────────────────────────────

# Dashboard URL for email links (update for production!)
VIGIL_DASHBOARD_URL=http://localhost:3000

# Hostname for email footers
VIGIL_HOSTNAME=vigil-home.local

# ── Rate Limiting ─────────────────────────────────────────────────

# Enable/disable rate limiting (default: true)
# VIGIL_RATE_LIMIT_ENABLED=true

# ── Logging ───────────────────────────────────────────────────────

# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
VIGIL_LOG_LEVEL=INFO

# Log file path (optional, defaults to console)
# VIGIL_LOG_FILE=/var/log/vigil/vigil.log

# ── Advanced ──────────────────────────────────────────────────────

# Timezone for timestamps (optional, defaults to UTC)
# TZ=America/New_York
