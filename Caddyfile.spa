# Vigil Caddy Configuration - SPA Support

# Dashboard frontend
:8080 {
	# CORS headers
	header {
		Access-Control-Allow-Origin "*"
		Access-Control-Allow-Methods "GET, POST, PUT, DELETE, OPTIONS"
		Access-Control-Allow-Headers "Content-Type, Authorization"
	}

	@options {
		method OPTIONS
	}
	respond @options 204

	# SPA support - redirect all paths to index.html
	try_files {path} {path}/ /index.html

	reverse_proxy dashboard:8080
}

# Backend API
:8000 {
	# CORS headers
	header {
		Access-Control-Allow-Origin "*"
		Access-Control-Allow-Methods "GET, POST, PUT, DELETE, OPTIONS"
		Access-Control-Allow-Headers "Content-Type, Authorization"
	}

	@options {
		method OPTIONS
	}
	respond @options 204

	reverse_proxy backend:8000
}

# Admin API
:2019 {
	bind 0.0.0.0
}
